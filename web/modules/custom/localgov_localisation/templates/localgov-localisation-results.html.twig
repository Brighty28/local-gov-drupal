{#
/**
 * @file
 * Localisation search results template.
 *
 * Variables:
 * - results: The API response data.
 * - postcode: The searched postcode.
 */
#}

{% if results %}
<div class="localisation-results">
  <h2 class="localisation-results__title">{{ 'Results for @postcode'|t({'@postcode': postcode}) }}</h2>

  {# Councillors #}
  {% if results.councillors is not empty %}
  <section class="localisation-results__section" id="results-councillors">
    <h3 class="localisation-results__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
      {{ 'Your Councillors'|t }}
    </h3>
    <div class="localisation-results__cards">
      {% for councillor in results.councillors %}
      <div class="councillor-card">
        {% if councillor.photoUrl %}
          <img src="{{ councillor.photoUrl }}" alt="{{ councillor.name }}" class="councillor-card__photo" loading="lazy">
        {% endif %}
        <div class="councillor-card__info">
          <h4 class="councillor-card__name">{{ councillor.name }}</h4>
          {% if councillor.party %}
            <p class="councillor-card__party">{{ councillor.party }}</p>
          {% endif %}
          {% if councillor.ward %}
            <p class="councillor-card__ward">{{ councillor.ward }}</p>
          {% endif %}
          {% if councillor.email %}
            <a href="mailto:{{ councillor.email }}" class="councillor-card__email">{{ councillor.email }}</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Bin Collections #}
  {% if results.collections is not empty %}
  <section class="localisation-results__section" id="results-collections">
    <h3 class="localisation-results__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
      {{ 'Bin Collections'|t }}
    </h3>
    <div class="localisation-results__list">
      {% for collection in results.collections %}
      <div class="collection-item">
        <div class="collection-item__type">{{ collection.type }}</div>
        <div class="collection-item__date">{{ 'Next collection: @date'|t({'@date': collection.nextDate}) }}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Planning Applications #}
  {% if results.planning is not empty %}
  <section class="localisation-results__section" id="results-planning">
    <h3 class="localisation-results__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
      {{ 'Planning Applications Nearby'|t }}
    </h3>
    <div class="localisation-results__list">
      {% for app in results.planning %}
      <div class="planning-item">
        <h4 class="planning-item__ref">
          {% if app.url %}
            <a href="{{ app.url }}" target="_blank" rel="noopener">{{ app.reference }}</a>
          {% else %}
            {{ app.reference }}
          {% endif %}
        </h4>
        {% if app.description %}
          <p class="planning-item__desc">{{ app.description }}</p>
        {% endif %}
        {% if app.address %}
          <p class="planning-item__address">{{ app.address }}</p>
        {% endif %}
        {% if app.status %}
          <span class="planning-item__status">{{ app.status }}</span>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Local Events #}
  {% if results.events is not empty %}
  <section class="localisation-results__section" id="results-events">
    <h3 class="localisation-results__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
      {{ 'Local Events'|t }}
    </h3>
    <div class="localisation-results__list">
      {% for event in results.events %}
      <div class="event-result">
        <h4 class="event-result__title">
          {% if event.url %}
            <a href="{{ event.url }}" target="_blank" rel="noopener">{{ event.title }}</a>
          {% else %}
            {{ event.title }}
          {% endif %}
        </h4>
        {% if event.date %}
          <p class="event-result__date">{{ event.date }}</p>
        {% endif %}
        {% if event.venue %}
          <p class="event-result__venue">{{ event.venue }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Democracy / Elections #}
  {% if results.democracy is not empty %}
  <section class="localisation-results__section" id="results-democracy">
    <h3 class="localisation-results__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M18 13h-.68l-2 2h1.91L19 17H5l1.78-2h2.05l-2-2H6l-3 3v4c0 1.1.89 2 1.99 2H19a2 2 0 002-2v-4l-3-3zm-1-5.05l-4.95 4.95-3.54-3.54 4.95-4.95L17 7.95zm-4.24-5.66L6.39 8.66a.996.996 0 000 1.41l4.95 4.95c.39.39 1.02.39 1.41 0l6.36-6.36a.996.996 0 000-1.41l-4.95-4.95a.996.996 0 00-1.41 0z"/></svg>
      {{ 'Elections & Democracy'|t }}
    </h3>
    <div class="localisation-results__list">
      {% for item in results.democracy %}
      <div class="democracy-item">
        <h4>{{ item.title }}</h4>
        {% if item.date %}
          <p>{{ item.date }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>
{% endif %}
