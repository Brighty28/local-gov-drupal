{#
/**
 * @file
 * SCDC theme implementation for a breadcrumb trail.
 *
 * Available variables:
 * - breadcrumb: Breadcrumb trail items.
 */
#}
{% if breadcrumb %}
  <nav class="breadcrumb" role="navigation" aria-label="{{ 'Breadcrumb'|t }}">
    <ol class="breadcrumb__list">
      {% for item in breadcrumb %}
        <li class="breadcrumb__item">
          {% if item.url %}
            <a href="{{ item.url }}" class="breadcrumb__link"{% if loop.last %} aria-current="page"{% endif %}>
              {{ item.text }}
            </a>
          {% else %}
            <span class="breadcrumb__link">{{ item.text }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
