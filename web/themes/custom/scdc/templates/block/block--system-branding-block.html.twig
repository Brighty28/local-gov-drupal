{#
/**
 * @file
 * SCDC theme implementation for a branding block.
 *
 * Available variables:
 * - site_logo: Logo for site.
 * - site_name: Name of site.
 * - site_slogan: Slogan of site.
 */
#}
{% set attributes = attributes.addClass('site-branding') %}

<div{{ attributes }}>
  {% if site_logo %}
    <a href="{{ path('<front>') }}" class="site-branding__logo" rel="home">
      <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" class="site-header__logo" />
    </a>
  {% endif %}

  {% if site_name %}
    <a href="{{ path('<front>') }}" class="site-header__site-name" rel="home">
      {{ site_name }}
    </a>
  {% endif %}

  {% if site_slogan %}
    <div class="site-branding__slogan">{{ site_slogan }}</div>
  {% endif %}
</div>
