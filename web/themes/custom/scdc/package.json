{
  "name": "scdc-theme",
  "version": "1.0.0",
  "description": "SCDC Drupal theme build tools",
  "private": true,
  "scripts": {
    "build": "npm run sass:build",
    "watch": "npm run sass:watch",
    "sass:build": "sass scss/main.scss css/style.css --style=compressed --source-map --load-path=scss --silence-deprecation=import",
    "sass:dev": "sass scss/main.scss css/style.css --source-map --load-path=scss --silence-deprecation=import",
    "sass:watch": "sass --watch scss/main.scss:css/style.css --source-map --load-path=scss --silence-deprecation=import",
    "lint:scss": "stylelint 'scss/**/*.scss'",
    "lint:js": "eslint js/**/*.js"
  },
  "devDependencies": {
    "sass": "^1.77.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "eslint": "^8.57.0"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
